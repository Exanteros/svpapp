# Copy this file to .env.docker or run ./docker-run.sh to generate it.
# Do not commit .env.docker. It contains production secrets.

NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=512
NEXT_TELEMETRY_DISABLED=1
PORT=3000
HOSTNAME=0.0.0.0

# Host publishing used by docker-run.sh and docker compose --env-file .env.docker.
APP_PORT=3000
BIND_ADDRESS=0.0.0.0

# Use https://... in production behind a TLS reverse proxy.
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_COOKIE_SECURE=false

DATABASE_PATH=/app/data/database.sqlite
DB_TIMEOUT=5000
DB_BUSY_TIMEOUT=5000

# Admin login for /admin/login.
ADMIN_EMAIL=admin@sv-puschendorf.de
ADMIN_PASSWORD=replace-with-a-generated-password
SESSION_SECRET=replace-with-a-generated-session-secret

# Legacy/internal secrets used by older helpers and referee-card tokens.
ADMIN_API_KEY=replace-with-a-generated-api-key
REFEREE_CARD_SECRET=replace-with-a-generated-referee-card-secret

# Optional mail settings.
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# TEAM_EMAIL_DOMAIN=
